cat > .gitignore << 'EOF'
# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
*.hcl
*.log

# Crash log files
crash.log
crash.*.log

# Local .terraform directories
**/.terraform/

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Node.js / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.codeium/
.cursor/

# Build outputs
dist/
build/
*.min.js
*.min.css

# Logs
logs/
*.log

# Coverage directory used by tools like istanbul
coverage/

# Temporary files
tmp/
temp/
*.tmp

# Terraform variable files
terraform.tfvars
terraform.tfvars.json

# Web files
*.sass-cache/
*.css.map
*.js.map
EOF